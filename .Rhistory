library(leaflet)
library(readxl)
library(dplyr)
library(rnaturalearth)
library(ggplot2)
library(sf)
data_centers <- read_excel("data/spain_datacenters_v2.xlsx")
spain <- ne_countries(scale = "medium", country = "Spain", returnclass = "sf")
# remove centers where we couldn't get lat/long
data_centers <- data_centers %>%
filter(!is.na(Latitude) & !is.na(Longitude))
# Radius based on power (MW)
data_centers <- data_centers %>%
mutate(
radius = case_when(
!is.na(`Power (MW)`) & `Power (MW)` >= 200 ~ 16,
!is.na(`Power (MW)`) & `Power (MW)` >= 100 ~ 13,
!is.na(`Power (MW)`) & `Power (MW)` >= 40  ~ 10,
!is.na(`Power (MW)`) & `Power (MW)` >= 10  ~ 7,
!is.na(`Power (MW)`) & `Power (MW)` > 0    ~ 5,
TRUE                                        ~ 3
)
)
ggplot() +
geom_sf(data = spain, fill = "grey95", color = "grey60") +
geom_point(
data = dc,
aes(x = Longitude, y = Latitude, color = City, size = radius),
alpha = 0.7
) +
scale_size_identity() +
coord_sf(xlim = c(-10, 5), ylim = c(27, 44)) +
labs(
title = "Data Centers in Spain",
subtitle = paste0(nrow(dc), " facilities across ", n_distinct(dc$City), " cities"),
color = "City"
) +
theme_minimal(base_size = 11) +
theme(
legend.position = "right",
legend.key.size = unit(0.4, "cm"),
legend.text = element_text(size = 7),
plot.title = element_text(face = "bold")
) +
guides(color = guide_legend(ncol = 1, override.aes = list(size = 3)))
ggplot() +
geom_sf(data = spain, fill = "grey95", color = "grey60") +
geom_point(
data = data_centers,
aes(x = Longitude, y = Latitude, color = City, size = radius),
alpha = 0.7
) +
scale_size_identity() +
coord_sf(xlim = c(-10, 5), ylim = c(27, 44)) +
labs(
