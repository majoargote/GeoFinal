data_center_map <- leaflet(data_centers) %>%
addTiles() %>%
addCircleMarkers(
~Longitude, ~Latitude,
radius = ~radius,
color = "blue",
fillOpacity = 0.6,
popup = ~paste0("<strong>Name:</strong> ", Name, "<br>",
"<strong>Power (MW):</strong> ", `Power (MW)`, "<br>",
"<strong>Location:</strong> ", Location),
addLegend(
position = "bottomright",
colors = c("blue"),
labels = c("Data Center"),
title = "City / Location")
